# Victim LLM (Groq or HuggingFace)
GROQ_API_KEY=your_groq_api_key
HF_TOKEN=your_huggingface_token
VICTIM_LLM_PROVIDER=groq
VICTIM_LLM_MODEL=llama-3.1-8b-instant

# Database
DATABASE_URL=sqlite:///./data/firewall.db

# MLflow
MLFLOW_TRACKING_URI=sqlite:///./mlruns/mlflow.db

# Policy
POLICY_VERSION=v1.0
MODEL_VERSION=v1.0
DATASET_VERSION=v1.0

# Airflow (optional)
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=

# GCP service account JSON for DVC GCS remote (local path; Docker uses /opt/airflow/secrets/gcp-key.json)
GOOGLE_APPLICATION_CREDENTIALS=.secrets/gcp-key.json
