# Airflow local development environment (see docker-compose.airflow.yml)

AIRFLOW_WEB_PORT=8080

# SMTP for Airflow EmailOperator (Gmail app password recommended)
AIRFLOW_SMTP_USER=
AIRFLOW_SMTP_PASSWORD=

# Hugging Face token for dataset ingestion inside Airflow containers
HF_TOKEN=

# GCS / DVC (production) — place service account JSON at .secrets/gcp-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/secrets/gcp-key.json
