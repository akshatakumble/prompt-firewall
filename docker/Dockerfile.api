FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY config/ config/
COPY schemas/ schemas/
COPY src/ src/

ENV PYTHONPATH=/app/src
ENV DATABASE_URL=sqlite:////app/data/firewall.db

EXPOSE 8000

CMD ["uvicorn", "firewall.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
